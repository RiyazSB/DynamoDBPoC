{
  "openapi": "3.0.0",
  "info": {
    "title": "DynamoDB Records API",
    "description": "API for managing records stored in DynamoDB with Redis caching",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://<API_GATEWAY_ID>.execute-api.us-east-1.amazonaws.com/prod",
      "description": "API Gateway endpoint (replace <API_GATEWAY_ID>)"
    }
  ],
  "paths": {
    "/api/records": {
      "get": {
        "summary": "List all records",
        "description": "Retrieve all records from DynamoDB. Results are cached for 5 minutes.",
        "operationId": "listRecords",
        "tags": ["Records"],
        "responses": {
          "200": {
            "description": "List of all records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Record" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new record",
        "description": "Create a new record in DynamoDB. Automatically generates a unique ID and timestamps.",
        "operationId": "createRecord",
        "tags": ["Records"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecordRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Record" }
              }
            }
          },
          "400": { "description": "Invalid request body" }
        }
      }
    },
    "/api/records/{id}": {
      "get": {
        "summary": "Get a specific record by ID",
        "description": "Retrieve a single record by its ID. Result is cached for 5 minutes.",
        "operationId": "getRecordById",
        "tags": ["Records"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The unique record ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Record found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Record" }
              }
            }
          },
          "404": { "description": "Record not found" }
        }
      },
      "put": {
        "summary": "Update an existing record",
        "description": "Update a record by its ID. Updates the updatedAt timestamp.",
        "operationId": "updateRecord",
        "tags": ["Records"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The unique record ID",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecordRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Record" }
              }
            }
          },
          "404": { "description": "Record not found" },
          "400": { "description": "Invalid request body" }
        }
      },
      "delete": {
        "summary": "Delete a record",
        "description": "Delete a record by its ID. Returns 204 No Content on success.",
        "operationId": "deleteRecord",
        "tags": ["Records"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The unique record ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Record deleted successfully" },
          "404": { "description": "Record not found" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Record": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique record identifier (UUID)"
          },
          "name": {
            "type": "string",
            "description": "The record name (max 120 characters)"
          },
          "description": {
            "type": "string",
            "description": "Optional description (max 1000 characters)"
          },
          "createdAt": {
            "type": "string",
            "description": "ISO 8601 timestamp when record was created"
          },
          "updatedAt": {
            "type": "string",
            "description": "ISO 8601 timestamp when record was last updated"
          }
        },
        "required": ["id", "name"]
      },
      "RecordRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The record name (required, max 120 characters)",
            "example": "My important record"
          },
          "description": {
            "type": "string",
            "description": "Optional description (max 1000 characters)",
            "example": "Details about this record"
          }
        },
        "required": ["name"]
      }
    }
  }
}
